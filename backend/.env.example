# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB Atlas ────────────────────────────────────────────────────────────
# Replace <username>, <password>, and <cluster-url> with your Atlas credentials
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/expense_tracker?retryWrites=true&w=majority

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Use a long, random, secret string — NEVER commit the real value to version control
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
# URL of the React Vite frontend dev server
CLIENT_ORIGIN=http://localhost:5173
