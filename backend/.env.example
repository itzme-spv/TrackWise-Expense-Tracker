# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB Atlas ────────────────────────────────────────────────────────────
# Replace with your Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/expense_tracker?retryWrites=true&w=majority

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
CLIENT_ORIGIN=http://localhost:5173

# ─── Rate Limiting (Phase A) ──────────────────────────────────────────────────
# These are hardcoded in server.js (15 req / 15 min) but documented here
# for reference. Override in server.js if needed.
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX=15
